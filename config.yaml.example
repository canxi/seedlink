# PT Hard Link Manager - 示例配置文件
# 复制此文件为 config.yaml 并修改相应配置

app:
  # 源文件夹路径 - PT 下载目录
  source_folder: /downloads

  # 目标文件夹路径 - 硬链接存放位置
  target_folder: /media

  # 最小视频时长（秒）
  # 低于此时长的视频不会创建硬链接
  # 默认 600 秒 = 10 分钟
  min_duration: 600

  # 扫描间隔（秒）
  scan_interval: 60

  # 监控的视频文件扩展名
  video_extensions:
    - .mkv
    - .mp4
    - .avi
    - .ts
    - .mov
    - .wmv
    - .flv

  # 调试模式 - 生产环境设为 false
  debug: false

database:
  # 数据库路径（容器内路径）
  uri: sqlite:////data/hardlinks.db
